# Required: one key for API auth and Flask sessions (SECRET_KEY is the same value)
API_KEY=change-me-to-a-long-random-string

HOST=0.0.0.0
PORT=7860

# Hugging Face model (weights stored under ./models by default)
MODEL_ID=Qwen/Qwen3-Omni-30B-A3B-Instruct
# MODELS_DIR=./models
# MODEL_PATH=./models/Qwen3-Omni-30B-A3B-Instruct

# transformers | vllm
INFERENCE_BACKEND=transformers
LOAD_MODEL_ON_STARTUP=true
MOCK_INFERENCE=false

# Generation defaults
MAX_NEW_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.95
RETURN_AUDIO=false
USE_AUDIO_IN_VIDEO=true
DEFAULT_SPEAKER=Ethan

UPLOAD_FOLDER=/tmp/qwen-uploads
MAX_CONTENT_LENGTH=104857600

# Hugging Face token (if model download requires auth)
# HF_TOKEN=hf_xxx
